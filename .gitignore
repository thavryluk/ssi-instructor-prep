# Built artifact (regenerated on Netlify build)
dist/

# Local-only state sync (per-machine, syncs via Dropbox not Git)
state/

# Node deps (Netlify installs on build)
node_modules/
package-lock.json

# Python build artifacts
__pycache__/
*.pyc

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Local environment
.env
.env.local

# Claude Code per-machine config
.claude/

# Dropbox conflict files (if any get committed)
*conflict*

# Intermediate translation chunks (reproducible via data/translate_split.py + agents)
data/cs/source/
data/cs/translated/

# Local Netlify folder
.netlify
